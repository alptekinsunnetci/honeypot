# Honeypot Suite configuration.
# Copy to ".env" and adjust. Real environment variables override these values.

# ----- DNS honeypot (UDP+TCP) -----
HONEYPOT_DNS_ENABLED=true
HONEYPOT_DNS_LISTEN=0.0.0.0:53
HONEYPOT_DNS_ANSWER_IPV4=192.168.1.1
HONEYPOT_DNS_ANSWER_IPV6=2001:db8::1
HONEYPOT_DNS_DOMAIN=example.com

# ----- RDP honeypot (NLA/CredSSP credential capture) -----
HONEYPOT_RDP_ENABLED=true
HONEYPOT_RDP_LISTEN=0.0.0.0:3389
HONEYPOT_RDP_CERT_ORG=example.com

# ----- SMB honeypot (SMBv1/v2 credential capture) -----
HONEYPOT_SMB_ENABLED=true
HONEYPOT_SMB_LISTEN=0.0.0.0:445

# ----- LDAP honeypot (simple-bind plaintext credential capture) -----
HONEYPOT_LDAP_ENABLED=true
HONEYPOT_LDAP_LISTEN=0.0.0.0:389
# Bind reply: "invalid" (49, looks like wrong password) or "success" (0)
HONEYPOT_LDAP_BIND_RESULT=invalid

# ----- NetBIOS Name Service honeypot (UDP) -----
HONEYPOT_NETBIOS_ENABLED=true
HONEYPOT_NETBIOS_LISTEN=0.0.0.0:137
HONEYPOT_NETBIOS_ANSWER_IPV4=192.168.1.1

# ----- FTP honeypot (USER/PASS capture) -----
HONEYPOT_FTP_ENABLED=true
HONEYPOT_FTP_LISTEN=0.0.0.0:21
HONEYPOT_FTP_BANNER=220 (vsFTPd 3.0.3)

# ----- Telnet honeypot (login/password capture) -----
HONEYPOT_TELNET_ENABLED=true
HONEYPOT_TELNET_LISTEN=0.0.0.0:23
# Optional pre-login banner (leave empty for none)
HONEYPOT_TELNET_BANNER=

# ----- SNMP honeypot (community string capture, UDP) -----
HONEYPOT_SNMP_ENABLED=true
HONEYPOT_SNMP_LISTEN=0.0.0.0:161

# ----- MySQL honeypot (username + auth scramble capture) -----
HONEYPOT_MYSQL_ENABLED=true
HONEYPOT_MYSQL_LISTEN=0.0.0.0:3306
HONEYPOT_MYSQL_VERSION=5.7.40

# ----- MSSQL honeypot (TDS, plaintext password capture) -----
HONEYPOT_MSSQL_ENABLED=true
HONEYPOT_MSSQL_LISTEN=0.0.0.0:1433

# ----- Redis honeypot (RESP AUTH capture) -----
HONEYPOT_REDIS_ENABLED=true
HONEYPOT_REDIS_LISTEN=0.0.0.0:6379
HONEYPOT_REDIS_REQUIRE_AUTH=true

# ----- HTTP honeypot (request + Basic-auth capture) -----
HONEYPOT_HTTP_ENABLED=true
HONEYPOT_HTTP_LISTEN=0.0.0.0:80
HONEYPOT_HTTP_SERVER=nginx
HONEYPOT_HTTP_REALM=Restricted

# ----- Logging -----
HONEYPOT_LOG_DIR=./logs
HONEYPOT_LOG_CONSOLE=true
HONEYPOT_LOG_LEVEL=info
